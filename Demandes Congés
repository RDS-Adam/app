<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portail RH - Gestion des Congés</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=Inter:wght@400;600;700&display=swap');

        :root {
            --primary: #0f172a; --accent: #3b82f6; --success: #10b981;
            --danger: #ef4444; --bg: #f8fafc; --surface: #ffffff;
            --text: #334155; --border: #e2e8f0;
        }

        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; }
        .container { max-width: 850px; margin: 0 auto; }
        
        header { text-align: center; margin-bottom: 30px; }
        
        .nav-tabs { display: flex; justify-content: center; gap: 10px; margin-bottom: 25px; }
        .tab-btn { padding: 10px 20px; border: none; background: #e2e8f0; cursor: pointer; border-radius: 50px; font-weight: 600; color: var(--text); }
        .tab-btn.active { background: var(--primary); color: white; }

        .section { display: none; }
        .section.active { display: block; }

        .card { background: var(--surface); padding: 25px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid var(--border); margin-bottom: 20px; }
        
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .full { grid-column: span 2; }
        label { display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 5px; color: var(--primary);}
        input, select, textarea { width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 1rem; box-sizing: border-box; font-family: 'Inter', sans-serif;}
        input:disabled { background: #e2e8f0; cursor: not-allowed; }

        button { cursor: pointer; transition: opacity 0.2s; }
        .btn-main { background: var(--primary); color: white; padding: 12px; border: none; border-radius: 8px; width: 100%; font-weight: 600; font-size: 1rem;}
        .btn-accent { background: var(--accent); color: white; padding: 12px; border: none; border-radius: 8px; width: 100%; font-weight: 600; font-size: 1rem;}
        .btn-gmail { background: #ea4335; color: white; text-decoration: none; display: block; text-align: center; padding: 12px; border-radius: 8px; font-weight: 600; margin-top: 15px; }
        
        .summary-box { background: #eff6ff; padding: 15px; border-radius: 10px; border: 1px solid #bfdbfe; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; }
        
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid var(--border); }
        .status { padding: 6px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
        .status-pending { background: #fef9c3; color: #a16207; }
        .status-valid { background: #dcfce7; color: #15803d; }
        .status-refused { background: #fee2e2; color: #b91c1c; }

        #pdf-template { display: none; background: white; color: black; }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>Demandes Congés</h1>
        <p>Responsable des validations : <strong>Nicolas Decoster</strong></p>
    </header>

    <div class="nav-tabs">
        <button id="btn-tab-emp" class="tab-btn active" onclick="switchTab('employee')">Espace Salarié</button>
        <button id="btn-tab-mgr" class="tab-btn" onclick="switchTab('manager')">Espace Direction</button>
    </div>

    <div id="employee" class="section active">
        <div id="emp-login" class="card" style="text-align:center;">
            <h2>Connexion</h2>
            <select id="user-selector" style="max-width: 300px; margin-bottom: 15px;">
                <option value="">-- Sélectionnez votre prénom --</option>
                <option value="Adam">Adam</option><option value="Alexandre">Alexandre</option>
                <option value="Axel">Axel</option><option value="Baptiste">Baptiste</option>
                <option value="Camille">Camille</option><option value="Cindy">Cindy</option>
                <option value="Clarisse">Clarisse</option><option value="Karine">Karine</option>
            </select><br>
            <button class="btn-main" style="max-width:200px" onclick="loginEmployee()">Ouvrir ma session</button>
        </div>

        <div id="emp-content" style="display:none;">
            <div class="card">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <h2 id="welcome-msg"></h2>
                    <button onclick="logoutEmployee()" style="background:#e2e8f0; border:none; border-radius:5px; padding:8px 12px; font-weight:bold;">Déconnexion</button>
                </div>
                
                <div class="form-grid">
                    <div class="full"><label>Email pro</label><input type="email" id="emp_email" placeholder="votre.email@entreprise.com"></div>
                    
                    <div><label>Nom de famille</label><input type="text" id="emp_lastname" placeholder="Votre nom"></div>
                    <div><label>Solde de congés actuel</label><input type="number" id="emp_solde" placeholder="Ex: 25" step="0.5"></div>
                    
                    <div><label>Date de Début</label><input type="date" id="date_start"></div>
                    <div><label>Date de Fin</label><input type="date" id="date_end"></div>
                    
                    <div>
                        <label>Type de congés</label>
                        <select id="leave_type" onchange="toggleAutre()">
                            <option value="Congés Payés">Congés Payés</option>
                            <option value="Congés Sans Solde">Congés Sans Solde</option>
                            <option value="Absence Exceptionnelle">Absence Exceptionnelle (Autre)</option>
                        </select>
                    </div>
                    <div>
                        <label>Si Autre, précisez :</label>
                        <input type="text" id="leave_autre" placeholder="Ex: Mariage, Déménagement..." disabled>
                    </div>
                </div>
                <button class="btn-accent" style="margin-top:20px;" onclick="processRequest()">📄 Valider et télécharger l'attestation PDF</button>
                
                <div id="action-request" style="display:none;">
                    <a href="#" id="gmail_link" class="btn-gmail" target="_blank">✉️ Notifier Nicolas Decoster par email</a>
                </div>
            </div>
            
            <div class="card">
                <h3>Mon historique</h3>
                <table>
                    <thead><tr><th>Dates</th><th>Jours</th><th>Statut</th></tr></thead>
                    <tbody id="my-requests-body"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="manager" class="section card">
        <div id="manager-lock" style="text-align:center;">
            <h3>Accès Direction</h3>
            <input type="password" id="mgr_pass" placeholder="Code secret" style="max-width:250px; text-align:center;"><br><br>
            <button class="btn-main" style="max-width:200px" onclick="unlockManager()">Se connecter</button>
        </div>

        <div id="manager-content" style="display:none;">
            <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
                <button onclick="lockManager()" style="background:#e2e8f0; border:none; padding:8px 15px; border-radius:5px; font-weight:bold;">🔒 Verrouiller</button>
                <button onclick="exportBackup()" style="background:var(--primary); color:white; border:none; padding:8px 15px; border-radius:5px; font-weight:bold;">💾 Sauvegarde JSON</button>
            </div>
            
            <h3>Demandes en attente de validation</h3>
            <div id="manager-list"></div>
            
            <div id="approval-form" class="card" style="display:none; background:#f1f5f9; border-left: 5px solid var(--accent); margin-top:20px;">
                <h3 id="val_display_name" style="margin-top:0; color:var(--accent);"></h3>
                <textarea id="refusal_reason" placeholder="Motif (Optionnel, utile si refus)" rows="2"></textarea><br><br>
                <div class="form-grid">
                    <button class="btn-accent" style="background:var(--success)" onclick="processDecision('Validé')">✅ Apposer le tampon VALIDÉ</button>
                    <button class="btn-main" style="background:var(--danger)" onclick="processDecision('Refusé')">❌ Apposer le tampon REFUSÉ</button>
                </div>
            </div>
            
            <div id="action-decision" style="display:none;">
                <a href="#" id="gmail_link_val" class="btn-gmail" target="_blank">✉️ Envoyer le document validé au salarié</a>
            </div>
        </div>
    </div>
</div>

<div id="pdf-template">
    <div id="pdf_body"></div>
</div>

<script>
    const PASS = "RH2026";
    const MGR_NAME = "Nicolas Decoster";
    const MGR_EMAIL = "nicolas.decoster@ruedustore.fr";
    let currentUser = null;
    let selectedRequestId = null;

    // --- UTILS ---
    function switchTab(tabName) {
        document.getElementById('employee').classList.remove('active');
        document.getElementById('manager').classList.remove('active');
        document.getElementById('btn-tab-emp').classList.remove('active');
        document.getElementById('btn-tab-mgr').classList.remove('active');

        document.getElementById(tabName).classList.add('active');
        if(tabName === 'employee') {
            document.getElementById('btn-tab-emp').classList.add('active');
        } else {
            document.getElementById('btn-tab-mgr').classList.add('active');
            lockManager(); 
        }
    }

    function toggleAutre() {
        const type = document.getElementById('leave_type').value;
        const autreInput = document.getElementById('leave_autre');
        if(type === 'Absence Exceptionnelle') {
            autreInput.disabled = false;
            autreInput.focus();
        } else {
            autreInput.disabled = true;
            autreInput.value = "";
        }
    }

    function formatDate(d) { if(!d) return ""; const [y,m,j] = d.split('-'); return `${j}/${m}/${y}`; }

    function calculateWorkDays(start, end) {
        let count = 0; let cur = new Date(start); let stop = new Date(end);
        while (cur <= stop) { if (cur.getDay() !== 0 && cur.getDay() !== 6) count++; cur.setDate(cur.getDate() + 1); }
        return count;
    }

    // --- LOGIQUE SALARIÉ ---
    function loginEmployee() {
        const val = document.getElementById('user-selector').value;
        if(!val) return alert("Choisissez un prénom");
        currentUser = val;
        document.getElementById('emp-login').style.display = 'none';
        document.getElementById('emp-content').style.display = 'block';
        document.getElementById('welcome-msg').innerText = "Espace de " + currentUser;
        renderEmployeeTable();
    }

    function logoutEmployee() {
        currentUser = null;
        document.getElementById('emp-login').style.display = 'block';
        document.getElementById('emp-content').style.display = 'none';
        document.getElementById('action-request').style.display = 'none';
    }

    async function processRequest() {
        const start = document.getElementById('date_start').value;
        const end = document.getElementById('date_end').value;
        const email = document.getElementById('emp_email').value;
        const lastname = document.getElementById('emp_lastname').value;
        const solde = document.getElementById('emp_solde').value;
        const type = document.getElementById('leave_type').value;
        const type_autre = document.getElementById('leave_autre').value;

        if(!start || !end || !email || !lastname) return alert("Veuillez remplir au minimum Email, Nom et Dates.");

        const days = calculateWorkDays(start, end);
        const soldeRestant = solde ? (parseFloat(solde) - days) : null;

        const req = { 
            id: Date.now(), 
            user: currentUser, 
            lastname: lastname,
            email: email, 
            start: start, 
            end: end, 
            days: days, 
            solde_actuel: solde,
            solde_restant: soldeRestant,
            type: type, 
            type_autre: type_autre,
            status: 'En attente',
            date_demande: new Date().toISOString().split('T')[0],
            reason: '' // Pour le refus éventuel
        };

        let db = JSON.parse(localStorage.getItem('requests_db') || '[]');
        db.push(req);
        localStorage.setItem('requests_db', JSON.stringify(db));

        // Générer le HTML du PDF et lancer le téléchargement
        document.getElementById('pdf_body').innerHTML = buildPDFHTML(req);
        await makePDF(`Demande_Conges_${req.user}.pdf`);
        
        renderEmployeeTable();
        
        // Mail simple de notification
        const body = `Bonjour Nicolas, \n\nUne nouvelle demande de congés a été effectuée sur le Portail RH par ${currentUser} ${lastname}. \n\nMerci de bien vouloir vous connecter à l'Espace Direction pour y apposer votre tampon de validation.\n\nCordialement.`;
        document.getElementById('gmail_link').href = `mailto:${MGR_EMAIL}?subject=Nouvelle demande de congés - ${currentUser}&body=${encodeURIComponent(body)}`;
        document.getElementById('action-request').style.display = 'block';
    }

    function renderEmployeeTable() {
        const db = JSON.parse(localStorage.getItem('requests_db') || '[]');
        const my = db.filter(r => r.user === currentUser).reverse();
        document.getElementById('my-requests-body').innerHTML = my.map(r => `
            <tr><td>Du ${formatDate(r.start)}<br>au ${formatDate(r.end)}</td><td>${r.days}</td><td><span class="status ${r.status === 'En attente' ? 'status-pending' : (r.status === 'Validé' ? 'status-valid' : 'status-refused')}">${r.status}</span></td></tr>
        `).join('');
    }

    // --- LOGIQUE DIRECTION ---
    function unlockManager() {
        if(document.getElementById('mgr_pass').value === PASS) {
            document.getElementById('manager-lock').style.display = 'none';
            document.getElementById('manager-content').style.display = 'block';
            renderManagerList();
        } else { alert("Code faux"); }
    }

    function lockManager() {
        document.getElementById('manager-lock').style.display = 'block';
        document.getElementById('manager-content').style.display = 'none';
        document.getElementById('mgr_pass').value = "";
        document.getElementById('action-decision').style.display = 'none';
        document.getElementById('approval-form').style.display = 'none';
    }

    function renderManagerList() {
        const db = JSON.parse(localStorage.getItem('requests_db') || '[]');
        const pending = db.filter(r => r.status === 'En attente');
        document.getElementById('manager-list').innerHTML = pending.length ? pending.map(r => `
            <div style="border:1px solid var(--border); padding:15px; margin-bottom:10px; border-radius:10px; background:white; display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <strong style="font-size:1.1rem; color:var(--primary);">${r.user} ${r.lastname}</strong><br>
                    ${r.days} jours (${r.type}) du ${formatDate(r.start)} au ${formatDate(r.end)}
                </div>
                <button class="btn-accent" style="width:auto;" onclick="selectForDecision(${r.id})">Traiter</button>
            </div>
        `).join('') : "<p style='color:var(--text-light);'>Aucune demande en attente.</p>";
    }

    function selectForDecision(id) {
        selectedRequestId = id;
        const r = JSON.parse(localStorage.getItem('requests_db')).find(x => x.id === id);
        document.getElementById('val_display_name').innerText = "Demande de " + r.user + " " + r.lastname;
        document.getElementById('refusal_reason').value = "";
        document.getElementById('approval-form').style.display = 'block';
        document.getElementById('action-decision').style.display = 'none';
    }

    async function processDecision(newStatus) {
        let db = JSON.parse(localStorage.getItem('requests_db'));
        const idx = db.findIndex(x => x.id === selectedRequestId);
        const r = db[idx];
        const reason = document.getElementById('refusal_reason').value;
        
        db[idx].status = newStatus;
        db[idx].reason = reason;
        localStorage.setItem('requests_db', JSON.stringify(db));

        // On regénère exactement le même PDF mais avec la case "Responsable" remplie !
        document.getElementById('pdf_body').innerHTML = buildPDFHTML(db[idx]);
        await makePDF(`${newStatus}_${r.user}.pdf`);
        
        const mailBody = `Bonjour ${r.user},\n\nSuite à votre demande, je vous informe que vos congés ont été ${newStatus.toLowerCase()}s.\nVeuillez trouver le document officiel tamponné en pièce jointe.\n\nCordialement,\n${MGR_NAME}`;
        document.getElementById('gmail_link_val').href = `mailto:${r.email}?subject=Réponse à votre demande de congés&body=${encodeURIComponent(mailBody)}`;
        document.getElementById('action-decision').style.display = 'block';
        document.getElementById('approval-form').style.display = 'none';
        renderManagerList();
    }

    // --- GÉNÉRATEUR HTML DU PDF COMPLET ---
    function buildPDFHTML(req) {
        const isCP = req.type === 'Congés Payés' ? 'X' : '&nbsp;&nbsp;';
        const isCSS = req.type === 'Congés Sans Solde' ? 'X' : '&nbsp;&nbsp;';
        const isOther = req.type === 'Absence Exceptionnelle' ? 'X' : '&nbsp;&nbsp;';
        const otherText = req.type === 'Absence Exceptionnelle' ? req.type_autre : '..............................';

        // Bloc du Responsable vide (si En attente) ou avec Tampon (si Validé/Refusé)
        let managerBox = `<strong>RESPONSABLE</strong><br><br>DATE ET SIGNATURE<br><br><br><br>`;
        
        if (req.status === 'Validé') {
            managerBox = `
                <strong>RESPONSABLE</strong><br><br>DATE ET SIGNATURE<br>Le ${new Date().toLocaleDateString('fr-FR')}<br>
                <div style="color: #15803d; border: 4px solid #15803d; padding: 15px; font-weight: 900; font-size: 22px; transform: rotate(-8deg); display: inline-block; margin-top: 15px; border-radius: 5px; text-transform:uppercase;">
                    VALIDÉ PAR<br>${MGR_NAME}
                </div>`;
        } else if (req.status === 'Refusé') {
            managerBox = `
                <strong>RESPONSABLE</strong><br><br>DATE ET SIGNATURE<br>Le ${new Date().toLocaleDateString('fr-FR')}<br>
                <div style="color: #b91c1c; border: 4px solid #b91c1c; padding: 15px; font-weight: 900; font-size: 22px; transform: rotate(-8deg); display: inline-block; margin-top: 15px; border-radius: 5px; text-transform:uppercase;">
                    REFUSÉ PAR<br>${MGR_NAME}
                </div>
                ${req.reason ? `<p style="color: #b91c1c; font-size: 13px; margin-top:10px; text-align:left;">Motif : ${req.reason}</p>` : ''}`;
        }

        return `
            <div style="font-family: Arial, sans-serif; color: black; padding: 20px;">
                <h1 style="text-align: center; font-size: 24px; text-decoration: underline; margin-bottom: 40px;">DEMANDE DE CONGES</h1>

                <div style="margin-bottom: 30px;">
                    <p><strong>NOM :</strong> ${req.lastname}</p>
                    <p><strong>PRENOM :</strong> ${req.user}</p>
                </div>

                <h3 style="font-size: 16px; margin-bottom: 10px; text-decoration: underline;">DATE CONGES SOUHAITES</h3>
                <div style="margin-bottom: 30px; padding-left: 20px;">
                    <p><strong>DATE DEBUT :</strong> ${formatDate(req.start)}</p>
                    <p><strong>DATE FIN :</strong> ${formatDate(req.end)}</p>
                </div>

                <div style="margin-bottom: 30px;">
                    <p><strong>SOLDE DE CONGES :</strong> ${req.solde_actuel || '....................'}</p>
                    <p><strong>NOMBRE DE CONGES SOUHAITES (jours ouvrés) :</strong> ${req.days}</p>
                    <p><strong>SOLDE DE CONGES RESTANT :</strong> ${req.solde_restant !== null ? req.solde_restant : '....................'}</p>
                </div>

                <h3 style="font-size: 16px; margin-bottom: 10px; text-decoration: underline;">TYPE CONGES</h3>
                <div style="margin-bottom: 50px; padding-left: 20px;">
                    <p>[ <strong style="font-size:18px;">${isCP}</strong> ] CONGES PAYES</p>
                    <p>[ <strong style="font-size:18px;">${isCSS}</strong> ] CONGES SANS SOLDE</p>
                    <p>[ <strong style="font-size:18px;">${isOther}</strong> ] AUTRES : <span style="text-decoration:underline;">${otherText}</span></p>
                </div>

                <table style="width: 100%; border-collapse: collapse; text-align: center; border: 2px solid black;">
                    <tr>
                        <td style="width: 50%; border: 2px solid black; padding: 15px; vertical-align: top; height: 220px;">
                            <strong>SALARIE</strong><br><br>
                            DATE ET SIGNATURE<br>
                            Le ${formatDate(req.date_demande)}<br><br>
                            <span style="font-family: 'Caveat', cursive; font-size: 38px; color: #000;">${req.user}</span>
                        </td>
                        <td style="width: 50%; border: 2px solid black; padding: 15px; vertical-align: top; height: 220px;">
                            ${managerBox}
                        </td>
                    </tr>
                </table>
            </div>
        `;
    }

    async function makePDF(name) {
        const el = document.getElementById('pdf-template');
        el.style.display = 'block';
        await html2pdf().set({ 
            margin: 15, 
            filename: name, 
            image: {type: 'jpeg', quality: 1}, 
            html2canvas: {scale: 3}, 
            jsPDF: {unit: 'mm', format: 'a4', orientation: 'portrait'} 
        }).from(el).save();
        el.style.display = 'none';
    }

    function exportBackup() {
        const data = localStorage.getItem('requests_db');
        const blob = new Blob([data], {type: 'application/json'});
        const a = document.createElement('a'); 
        a.href = URL.createObjectURL(blob); 
        a.download = `Backup_Conges_${new Date().toISOString().split('T')[0]}.json`; 
        a.click();
    }
</script>
</body>
</html>
