<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Calculateur Diamètre d'Enroulement</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    .calculateur {
      max-width: 500px; margin: auto; border: 1px solid #ddd;
      border-radius: 8px; padding: 20px;
    }
    label, input, select, button {
      display: block; width: 100%; margin: 10px 0;
    }
    button { padding: 10px; cursor: pointer; }
    .resultat {
      margin-top: 15px; padding: 10px; background: #f3f3f3;
      border: 1px solid #ccc; border-radius: 5px;
    }
  </style>
</head>
<body>

<div class="calculateur">
  <h2>Calculateur de Diamètre d'Enroulement</h2>
  
  <label for="tubeEnroulement">Tube d'enroulement nu (sélectionnez le diamètre) :</label>
  <select id="tubeEnroulement">
    <option value="6">6 cm</option>
    <option value="7">7 cm</option>
    <option value="8">8 cm</option>
  </select>
  
  <label for="qualite">Qualité de la toile :</label>
  <select id="qualite">
    <!-- Affichage en mm tout en utilisant des valeurs en cm dans le calcul -->
    <option value="acrylique">Acrylique (épaisseur 1,6 mm)</option>
    <option value="soltis">Soltis 92 (épaisseur 0,5 mm)</option>
  </select>
  
  <label for="avancee">Longueur de l'avancée (cm) :</label>
  <input type="number" id="avancee" placeholder="Ex : 200" min="0" step="1">
  
  <button type="button" onclick="calculerDiametre()">Calculer</button>
  
  <div id="resultat" class="resultat"></div>
</div>

<script>
  function calculerDiametre() {
    // Récupération des valeurs
    let dTube = parseFloat(document.getElementById('tubeEnroulement').value);
    let qualite = document.getElementById('qualite').value;
    let L = parseFloat(document.getElementById('avancee').value);
    let t; // épaisseur de la toile en cm

    // Debug : affichage des valeurs récupérées
    console.log("Tube : " + dTube + ", Qualité : " + qualite + ", Avancée : " + L);

    // Vérification des entrées
    if (isNaN(dTube) || dTube <= 0) {
      document.getElementById('resultat').innerHTML = "❗️Veuillez sélectionner un tube d'enroulement valide.";
      return;
    }
    if (isNaN(L) || L <= 0) {
      document.getElementById('resultat').innerHTML = "❗️Veuillez entrer une longueur d'avancée valide (> 0).";
      return;
    }

    // Définition de l'épaisseur selon la qualité de la toile (conversion en centimètres)
    if (qualite === "acrylique") {
      t = 0.16; // 1,6 mm = 0,16 cm
    } else if (qualite === "soltis") {
      t = 0.05; // 0,5 mm = 0,05 cm
    }

    // Calcul du diamètre final d'enroulement (en cm)
    let dFinal = Math.sqrt(dTube * dTube + (4 * t * L) / Math.PI);
    dFinal = Math.round(dFinal * 10) / 10; // arrondi à une décimale

    // Affichage du résultat
    document.getElementById('resultat').innerHTML = 
      `Diamètre final d'enroulement : <strong>${dFinal} cm</strong><br>
       Vérifiez que ce diamètre rentre dans l'espace disponible de votre coffre de Store banne. Nous vous conseillons d'ajouter une marge d'erreur au résultat calculé.`;
  }
</script>

</body>
</html>
