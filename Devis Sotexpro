  const tbody  = document.getElementById("tbody");
  const thead  = document.getElementById("thead");
  const empty  = document.getElementById("empty");
  const totc   = document.getElementById("totcard");
  const acts   = document.getElementById("acts");
  const remc   = document.getElementById("remcard");

  if (!items.length) {
    empty.style.display=""; thead.style.display="none"; totc.style.display="none"; acts.style.display="none"; remc.style.display="none";
    tbody.innerHTML="";
    return;
  }
  empty.style.display="none"; thead.style.display="grid"; totc.style.display=""; acts.style.display="grid"; remc.style.display="flex";

  tbody.innerHTML = items.map((it,i) => {
    const tot = it.puC * it.qty;
    const bc  = it.type==="rideau" ? "rb-r" : it.type==="rail" ? "rb-rail" : "rb-tr";
    const bt  = it.
