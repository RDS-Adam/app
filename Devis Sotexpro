function qpx(row, qty) {
  if (qty > 10) return row.q10;
  if (qty >= 5)  return row.q5;
  if (qty >= 2)  return row.q2;
  return row.q1;
}

function qlabel(qty) {
  if (qty > 10) return ">10"; if (qty >= 5) return "5–10"; if (qty >= 2) return "2–4"; return "1";
}

function fmt(v) { return v.toFixed(2).replace(".", ",") + " €"; }
function today() { return new Date().toLocaleDateString("fr-FR",{day:"2-digit",month:"long",year:"numeric"}); }
function clamp(v,mn,mx){ return Math.min(mx,Math.max(mn,v)); }

function findRideauRow(rows, larg, haut) {
  const Ls = [...new Set(rows.map(r=>r.l))].sort((a,b)=>a-b);
  const Hs = [...new Set(rows.map(r=>r.h))].sort((a,b)=>a-b);
  const l = clamp(larg, Ls[0], Ls[Ls.length-1]);
  const h = clamp(haut, Hs[0], Hs[Hs.length-1]);

  let L1=Ls[0], L2=Ls[Ls.length-1];
  for (let i=0;i<Ls.length-1;i++) { if(Ls[i]<=l&&l<=Ls[i+1]){L1=Ls[i];L2=Ls[i+1];break;} }
  let H1=Hs[0], H2=Hs[Hs.length-1];
  for (let i=0;i<Hs.length-1;i++) { if(Hs[i]<=h&&h<=Hs[i+1]){H1=Hs[i];H2=Hs[i+1];break;} }

  const g = (lv,hv) => rows.find(r=>r.l===lv&&r.h===hv);
  const r11=g(L1,H1), r12=g(L1,H2), r21=g(L2,H1), r22=g(L2,H2);
  if (!r11||!r12||!r21||!r22) return null;

  const tl = L1===L2 ? 0 : (l-L1)/(L2-L1);
  const th = H1===H2 ? 0 : (h-H1)/(H2-H1);

  const interp = f => r11[f]*(1-tl)*(1-th) + r21[f]*tl*(1-th) + r12[f]*(1-tl)*th + r22[f]*tl*th;

  return {
    l, h, L1, L2, H1, H2,
    refL: tl===0?L1:(tl===1?L2:`${L1}–${L2}`),
    refH: th===0?H1:(th===1?H2:`${H1}–${H2}`),
    q1:interp("q1"), q2:interp("q2"), q5:interp("q5"), q10:interp("q10"),
    e:interp("e"),
    p2: r22.p2||r21.p2||r12.p2||r11.p2||0,
    interp: (tl>0&&tl<1)||(th>0&&th<1)
  };
}

function findRailRow(rows, larg) {
  const Ls = [...new Set(rows.map(r=>r.l))].sort((a,b)=>a-b);
  const l = clamp(larg, Ls[0], Ls[Ls.length-1]);
  let L1=Ls[0], L2=Ls[Ls.length-1];
  for (let i=0;i<Ls.length-1;i++) { if(Ls[i]<=l&&l<=Ls[i+1]){L1=Ls[i];L2=Ls[i+1];break;} }
  const r1=rows.find(r=>r.l===L1), r2=rows.find(r=>r.l===L2);
  if(!r1||!r2) return null;
  const t = L1===L2 ? 0 : (l-L1)/(L2-L1);
  return {
    l, refL: t===0?L1:(t===1?L2:`${L1}–${L2}`),
    q1:r1.q1*(1-t)+r2.q1*t, q2:r1.q2*(1-t)+r2.q2*t,
    q5:r1.q5*(1-t)+r2.q5*t, q10:r1.q10*(1-t)+r2.q10*t,
    e:r1.e*(1-t)+r2.e*t, s3:r2.s3||r1.s3,
    interp: t>0&&t<1
  };
}

