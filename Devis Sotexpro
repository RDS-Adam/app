function onGamme() {
  const g = document.getElementById("gamme").value;
  const pmps = document.getElementById("ch-pmps");
  const gi = document.getElementById("g-info");
  
  pmps.style.display = g === "BORNEO" ? "inline-block" : "none";
  
  // Bascule automatique de la tête selon le tissu choisi
  if (g === "BORNEO" && tete === "PP70") {
    // Borneo n'accepte pas PP70, on force PMPS
    setTete(document.querySelector('.chip[data-val="PMPS"]'));
  } else if (g !== "BORNEO" && tete === "PMPS") {
    // Si on quitte Borneo, on remet PP70 par défaut car PMPS est caché
    setTete(document.querySelector('.chip[data-val="PP70"]'));
  }

  gi.innerHTML = g && GINFOS[g] ? `<div class="ginfo-card">${GINFOS[g]}</div>` : "";
  calcBoth();
}

function calcBoth() {
  calcR();
  calcT();
}

function calcR() {
  const g   = document.getElementById("gamme").value;
  const larg = parseFloat(document.getElementById("r-l").value) || 0;
  const haut = parseFloat(document.getElementById("r-h").value) || 0;
  const qty  = parseInt(document.getElementById("r-q").value)   || 1;

  const mbox = document.getElementById("r-match");
  const pbox = document.getElementById("r-px");
  const abox = document.getElementById("r-alert");
  mbox.style.display = pbox.style.display = abox.style.display = "none";

  if (!g || larg < 50 || haut < 50) return;

  let tk = tete;
  if (g==="BORNEO" && tk==="PP70") tk = "PMPS";

  const tdata = TARIFS[g] && TARIFS[g][tk];
  if (!tdata) { showMsg(abox,"err","Combinaison tissu/tête indisponible."); return; }

  const row = findRideauRow(tdata.rows, larg, haut);
  if (!row) { showMsg(abox,"err","Données introuvables pour ces dimensions."); return; }

  const puF = qpx(row, qty);
  const puC = puF * coef;
  const tot = puC * qty;

  mbox.innerHTML = `<div class="match-card">Tarif interpolé sur <strong>${row.refL}×${row.refH} cm</strong>${row.interp?" (interpolation linéaire)":""} · bracket qté : <strong>${qlabel(qty)}</strong>${row.p2?" · <span style='color:#B45309'>⚠ livraison 2 pans</span>":""}</div>`;
  mbox.style.display = "";

  pbox.innerHTML = `
    <div class="px-client" style="margin-top:0">
      <div><div class="lbl">PU HT (dont écopart ${row.e.toFixed(2)} €)</div><div class="sub">Total ${qty} u. = <strong>${fmt(tot)}</strong></div></div>
      <div class="val">${fmt(puC)}</div>
    </div>`;
  pbox.style.display = "";

  if (row.p2) showMsg(abox,"warn","⚠ Pour cette largeur et tête TO, le rideau est livré en 2 pans.");
}

const RINFOS = {
  KS:"Rail KS alu 15×20mm · max 600cm · Idéal pose plafond silencieuse · coloris blanc/gris/noir",
  KSC:"Rail KSC alu 20×20mm · max 600cm · Rideaux lourds 12kg/ml · Hôtels/bureaux/écoles",
  SHUTTLE:"Rail Shuttle motorisé · Touch Control · Télécommande incluse · max 40kg rideau",
  TR20:"Tringle ronde acier chromé Ø20mm · max 300cm · Décorative · TO ou anneaux STAN"
};

function onRailType() {
  const r = document.getElementById("rail-type").value;
  document.getElementById("rt-info").innerHTML = r&&RINFOS[r] ? `<div class="ginfo-card">${RINFOS[r]}</div>` : "";
  document.getElementById("t-pose-wrap").style.display = (r==="SHUTTLE"||r==="TR20") ? "none" : "";
  calcBoth();
}

function calcT() {
  const r    = document.getElementById("rail-type").value;
  const larg = parseFloat(document.getElementById("r-l").value) || 0; // Valeur partagée
  const qty  = parseInt(document.getElementById("r-q").value)  || 1;  // Valeur partagée
  const col  = document.getElementById("t-col").value;
  const pose = document.getElementById("t-pose").value;

  const mbox = document.getElementById("t-match");
  const pbox = document.getElementById("t-px");
  const abox = document.getElementById("t-alert");
  mbox.style.display = pbox.style.display = abox.style.display = "none";

  if (!r || larg < 50) return;
  const rd = RAILS[r];
  if (!rd) return;

  if (r==="KSC" && col!=="blanc") { showMsg(abox,"err","Rail KSC disponible en blanc uniquement."); return; }
  if (r==="TR20" && larg > 300)   { showMsg(abox,"warn","⚠ Tringle TR20 : max 300cm sans raccord. Nous consulter au-delà."); }
  if (r==="SHUTTLE" && larg > 400){ showMsg(abox,"err","Rail Shuttle : max 400cm."); return; }

  const row = findRailRow(rd.rows, larg);
  if (!row) return;

  let puF = qpx(row, qty);
  const notes = [];
  if (col !== "blanc") {
    const pct = r==="SHUTTLE" ? .10 : .08;
    puF *= (1 + pct);
    notes.push(`+${r==="SHUTTLE"?"10":"8"} % coloris ${col}`);
  }
  let minsv = 0;
  if (pose==="plafond" && r!=="TR20" && r!=="SHUTTLE") {
    minsv = 1.55 * (larg / 100);
    puF = Math.max(0, puF - minsv);
    notes.push(`−${minsv.toFixed(2)} € pose plafond`);
  }

  const puC = puF * coef;
  const tot = puC * qty;

  mbox.innerHTML = `<div class="match-card">Tarif sur <strong>${row.refL} cm</strong>${row.interp?" (interpolation)":""} · bracket : <strong>${qlabel(qty)}</strong>${notes.length?" · "+notes.join(", "):""}</div>`;
  mbox.style.display = "";

  pbox.innerHTML = `
    <div class="px-client" style="margin-top:0">
      <div><div class="lbl">PU HT (dont écopart ${row.e.toFixed(2)} €)</div><div class="sub">Total ${qty} u. = <strong>${fmt(tot)}</strong></div></div>
      <div class="val">${fmt(puC)}</div>
    </div>`;
  pbox.style.display = "";

  if (row.s3) showMsg(abox, "warn", "3 supports nécessaires pour cette longueur.");
}

function showMsg(el, type, msg) {
  el.innerHTML = msg;
  el.className = type==="err" ? "err" : "warn";
  el.style.display = "";
}

function addBoth() {
  const g = document.getElementById("gamme").value;
  const r = document.getElementById("rail-type").value;

  if (!g && !r) { alert("Sélectionnez au moins un tissu ou un rail."); return; }

  const larg = parseFloat(document.getElementById("r-l").value) || 0;
  const qty  = parseInt(document.getElementById("r-q").value)   || 1;
  let added = false;

  // AJOUT RIDEAU
  if (g) {
    const haut = parseFloat(document.getElementById("r-h").value) || 0;
    const col  = document.getElementById("r-col").value.trim();

    if (larg < 50 || haut < 50) { alert("Rideau : Saisir des dimensions valides (min 50 cm)."); return; }
    
    let tk = tete;
    if (g==="BORNEO" && tk==="PP70") tk = "PMPS";
    const tdata = TARIFS[g] && TARIFS[g][tk];
    if (!tdata) { alert("Rideau : Combinaison indisponible."); return; }

    const row = findRideauRow(tdata.rows, larg, haut);
    if (!row) { alert("Rideau : Données introuvables."); return; }

    const puF = qpx(row, qty);
    const puC = puF * coef;

    items.push({
      type:"rideau",
      name:`${g} ${tk} — ${larg}×${haut} cm${col?" — "+col:""}`,
      detail:`Ampleur ×${tdata.amp} · bracket: ${qlabel(qty)}${row.interp?" · interpolé":""}${row.p2?" · 2 pans":""}`,
      qty, puF, puC, eco:row.e
    });
    added = true;
  }

  // AJOUT RAIL
  if (r) {
    const col  = document.getElementById("t-col").value;
    const pose = document.getElementById("t-pose").value;

    if (larg < 50){ alert("Rail : Saisir une largeur valide."); return; }
    const rd = RAILS[r];
    const row = findRailRow(rd.rows, larg);
    if (!row) { alert("Rail : Largeur hors plage."); return; }
    if (r==="KSC" && col!=="blanc") { alert("Rail KSC disponible en blanc uniquement."); return; }

    let puF = qpx(row, qty);
    const notes = [];
    if (col !== "blanc") {
      const pct = r==="SHUTTLE" ? .10 : .08;
      puF *= (1 + pct);
      notes.push(`coloris ${col}`);
    }
    if (pose==="plafond" && r!=="TR20" && r!=="SHUTTLE") {
      const m = 1.55 * (larg / 100);
      puF = Math.max(0, puF - m);
      notes.push("pose plafond");
    }

    const puC = puF * coef;
    items.push({
      type: r==="TR20" ? "tringle" : "rail",
      name:`${rd.label} — ${larg} cm${col!=="blanc"?" "+col:""}`,
      detail:`Pose ${pose} · bracket: ${qlabel(qty)}${notes.length?" · "+notes.join(", "):""}${row.interp?" · interpolé":""}`,
      qty, puF, puC, eco:row.e
    });
    added = true;
  }

  if (added) {
    render();
  }
}

